# ── Supabase (client-side, safe to expose) ───────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Claude API key — NEVER put it here ────────────────────────────────────────
# The key is stored as a Supabase secret (server-side only) and never reaches
# the browser. Set it once via the CLI:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# Optionally override the model (default: claude-sonnet-4-6):
#   supabase secrets set CLAUDE_MODEL=claude-opus-4-8
